###############################################################################
# Application
###############################################################################
APP_NAME="B2B Ministore"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US
APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database
BCRYPT_ROUNDS=12
###############################################################################
# Logging
###############################################################################
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug
###############################################################################
# Database (MySQL 8 - "mysql" is the docker compose service name)
###############################################################################
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=ecommerce
DB_USERNAME=ecommerce
DB_PASSWORD=secret
# Used by the MySQL container only (root account). Keep in sync with compose.
DB_ROOT_PASSWORD=root
###############################################################################
# Session (stored in the database -> requires the "sessions" migration)
###############################################################################
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
###############################################################################
# Cache & Queue (backed by Redis)
###############################################################################
CACHE_STORE=redis
# CACHE_PREFIX=
QUEUE_CONNECTION=redis
###############################################################################
# Broadcasting (Laravel Reverb websockets)
###############################################################################
BROADCAST_CONNECTION=reverb
###############################################################################
# Redis ("redis" is the docker compose service name)
# ---------------------------------------------------------------------------
# IMPORTANT: This hostname only works INSIDE Docker containers.
# When running PHP on the Windows host, use: REDIS_HOST=127.0.0.1, REDIS_PORT=6380
###############################################################################
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379
###############################################################################
# Filesystem
###############################################################################
FILESYSTEM_DISK=local
###############################################################################
# Mail (logged to storage/logs during local development)
###############################################################################
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"
###############################################################################
# AWS (placeholder, unused for now)
###############################################################################
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false
###############################################################################
# Laravel Reverb
# ---------------------------------------------------------------------------
# REVERB_HOST / REVERB_PORT  -> used SERVER-SIDE (php app -> reverb container),
#   so it points at the "reverb" docker service on the internal network.
# REVERB_SERVER_HOST/PORT     -> the address Reverb binds to inside its container.
# VITE_REVERB_*               -> used by the BROWSER, so it points at the host
#   machine ("localhost") on the published port.
###############################################################################
REVERB_APP_ID=413425
REVERB_APP_KEY=gicznliacki6vbj0xuxk
REVERB_APP_SECRET=zgionky8bnmsphvxgvxx
REVERB_HOST=reverb
REVERB_PORT=8080
REVERB_SCHEME=http
REVERB_SERVER_HOST=0.0.0.0
REVERB_SERVER_PORT=8080
VITE_APP_NAME="${APP_NAME}"
VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST=localhost
VITE_REVERB_PORT=8080
VITE_REVERB_SCHEME=http###############################################################################
# Docker published host ports
# ---------------------------------------------------------------------------
# Override these if a port is already in use on the host machine.
# They ONLY affect the host-side mapping; container-internal ports are fixed.
###############################################################################
APP_HTTP_PORT=80
FORWARD_DB_PORT=3306
FORWARD_REDIS_PORT=6379
FORWARD_REVERB_PORT=8080
FORWARD_VITE_PORT=5173
